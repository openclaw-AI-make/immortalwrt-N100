#
# ImmortalWrt x86_64 Configuration for Intel N100
# Optimized build configuration with essential plugins
#

# Target System
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# Kernel
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# Network Configuration
CONFIG_TARGET_x86_64_DEFAULT_DEVICE_INFO_LAN_IP="192.168.10.4"

# Image Options
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_VMDK_IMAGES=y
CONFIG_VDI_IMAGES=y
CONFIG_QCOW2_IMAGES=y

# Kernel Features
CONFIG_KERNEL_GCC_VERSION_12=y
CONFIG_KERNEL_6_6=y
CONFIG_KERNEL_6_6_69=y
CONFIG_KERNEL_PATCHVER_6_6=y

# Base System
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_blockd=y
