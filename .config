CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_IMAGES_GZIP=y

# EXT4 + EFI
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_EFI_IMAGES=y

# LuCI
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-compat=y

# OpenClash (主力代理)
CONFIG_PACKAGE_luci-app-openclash=y

# v2rayA (备用代理) - 暂时禁用，Go 依赖问题
# v2rayA 依赖 xray-core，xray-core 需要 github.com/sagernet/sing 模块
# 该模块在 feeds 中缺失，导致编译失败
# 使用 OpenClash 作为唯一代理解决方案
CONFIG_PACKAGE_v2raya=n
CONFIG_PACKAGE_luci-app-v2raya=n

# AdGuard Home (去广告)
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# MosDNS (DNS 分流)
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# Turbo ACC (网络加速，无 SFE)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_kmod-shortcut-fe=n
CONFIG_PACKAGE_kmod-shortcut-fe-cm=n
CONFIG_PACKAGE_kmod-shortcut-fe-drv=n
CONFIG_PACKAGE_kmod-fast-classifier=n

# WireGuard (VPN)
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-i18n-wireguard-zh-cn=y

# TTYD 终端
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# 网络基础
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y

# 防火墙
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_nftables=y

# 网卡驱动
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-tg3=y
CONFIG_PACKAGE_kmod-virtio-net=y

# USB/存储
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y

# 系统工具
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_luci-app-opkg=y

# TCP BBR 加速
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_tcp_bbr=y

# ========== 明确禁用的包 ==========

# Passwall 系列 - 用 v2rayA 替代
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-passwall2=n
CONFIG_PACKAGE_luci-app-ssr-plus=n
CONFIG_PACKAGE_luci-app-homeproxy=n

# 问题包
CONFIG_PACKAGE_geoview=n
CONFIG_PACKAGE_v2ray-plugin=n
CONFIG_PACKAGE_sing-box=n

# ========== 启用的包 ==========

# frpc (从 kuoruan 源，兼容 Go 1.24)
CONFIG_PACKAGE_frpc=y
CONFIG_PACKAGE_luci-app-frpc=y

# xray-core - 禁用，Go 依赖 github.com/sagernet/sing 缺失
# 与 v2rayA 一同禁用，解决编译错误
CONFIG_PACKAGE_xray-core=n
CONFIG_PACKAGE_xray-plugin=n
