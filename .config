# ============================================
# Security
# ============================================
CONFIG_PACKAGE_fail2ban=y
CONFIG_PACKAGE_luci-app-fail2ban=y

# ============================================
# Hardware Monitoring
# ============================================
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_luci-app-cpufreq=y
