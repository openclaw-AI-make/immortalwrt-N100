CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_HAS_SUBTARGETS=y
CONFIG_HAS_DEVICES=y
CONFIG_TARGET_IMAGES_GZIP=y

# 只保留 squashfs + efi
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_EFI_IMAGES=y
# CONFIG_GRUB_IMAGES is not set

# LuCI
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-nginx=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-compat=y

# OpenClash
CONFIG_PACKAGE_luci-app-openclash=y

# AdGuard Home (LuCI only, core downloaded at runtime)
# CONFIG_PACKAGE_adguardhome is not set
CONFIG_PACKAGE_luci-app-adguardhome=y

# Turbo ACC
CONFIG_PACKAGE_luci-app-turboacc=y

# frpc — disabled: pion/dtls/v2 Go module broken in frp 0.57.0
# Install frpc later via opkg if needed
# CONFIG_PACKAGE_frpc is not set
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE_luci-i18n-frpc-zh-cn is not set

# SSR Plus+ (fw876/helloworld) — 备用代理
CONFIG_PACKAGE_luci-app-ssr-plus=y

# WireGuard
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# Passwall disabled: sing-box 1.12.22 requires Go>=1.24, incompatible
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_sing-box is not set

# ---------- 显式禁用 homeproxy（如果不需要） ----------
# CONFIG_PACKAGE_luci-app-homeproxy is not set

# ---------- 补全 ssr-plus 依赖 ----------
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y
CONFIG_PACKAGE_shadowsocks-libev-ss-server=y
CONFIG_PACKAGE_libpcre=y

# ---------- 补全 turboacc 依赖 ----------
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
CONFIG_PACKAGE_kmod-shortcut-fe-drv=y

# 常用网络增强
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_uhttpd=y

# x86 常用网卡驱动
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-tg3=y
CONFIG_PACKAGE_kmod-virtio-net=y

# USB/存储
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y

# 中文
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# 保留固件管理/常用页
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-firewall=y
