# ImmortalWrt x86_64 Configuration Seed
# Target: N100 CPU, EFI + BIOS Dual Support

# Target System
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE=y
CONFIG_TARGET_PROFILE="Generic"

# Kernel
CONFIG_KERNEL_6_1=y
CONFIG_KERNEL_PATCHVER="6.1"

# Image Options
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_EXT4_IMAGES=y
CONFIG_TARGET_SQUASHFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_MAXSIZE=512

# EFI Support
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_GRUB_TIMEOUT=3

# Package Selection - Base
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_cgi-io=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-dnspod=y
